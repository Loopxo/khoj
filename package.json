{
  "name": "khoj",
  "version": "2.1.4",
  "description": "An intelligent CLI tool that extracts token-optimized context, animations, and pixel-perfect clones from any website to power AI coding agents.",
  "private": false,
  "type": "module",
  "bin": {
    "khoj": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "khoj-context.schema.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "web-scraping",
    "ai-context",
    "cli",
    "playwright",
    "design-tokens",
    "llm",
    "site-analysis"
  ],
  "author": "Vijeet Shah <vijeet@vijeetshah.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vijeet-shah/khoj.git"
  },
  "homepage": "https://github.com/vijeet-shah/khoj#readme",
  "bugs": {
    "url": "https://github.com/vijeet-shah/khoj/issues"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.0.1",
    "playwright": "^1.46.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^2.0.3",
    "eslint": "^8.57.0",
    "tsx": "^4.20.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}