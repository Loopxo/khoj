{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://khoj.dev/schema/khoj-context.schema.json",
    "title": "KhojContext",
    "description": "Output schema generated by the Khoj CLI (token-efficient website context)",
    "type": "object",
    "properties": {
        "schemaVersion": {
            "type": "string",
            "const": "1.0"
        },
        "url": {
            "type": "string",
            "format": "uri"
        },
        "finalUrl": {
            "type": "string",
            "format": "uri"
        },
        "extractedAt": {
            "type": "string",
            "format": "date-time"
        },
        "loadTimeMs": {
            "type": "number"
        },
        "tokenEstimate": {
            "type": "number",
            "description": "Estimated LLM tokens for the JSON payload"
        }
    },
    "required": [
        "schemaVersion",
        "url",
        "finalUrl",
        "extractedAt",
        "loadTimeMs",
        "tokenEstimate",
        "meta",
        "structure",
        "designTokens",
        "components",
        "assets",
        "content",
        "interactions",
        "animations"
    ]
}